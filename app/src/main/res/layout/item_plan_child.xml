<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:clipChildren="false">

    <View
        android:id="@+id/popupAnchor"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_gravity="top|end"
        android:background="@android:color/transparent" />

    <LinearLayout
        android:id="@+id/childLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="8dp"
        android:paddingVertical="12dp"
        android:background="@drawable/bg_plan_child_solid">
        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/shape_circle_dot"
            android:backgroundTint="#B0BEC5"
            android:layout_marginEnd="12dp"/>

        <TextView
            android:id="@+id/tvDayName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Day 1: 推力日"
            android:textSize="16sp"
            android:textColor="#546E7A"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/ivDayDragHandle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_hand_grab"
            app:tint="#CFD8DC"
            android:padding="6dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>
</FrameLayout>