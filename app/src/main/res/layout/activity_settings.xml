<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".SettingsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:paddingHorizontal="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="12dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="身体维度 (用于智能分析)"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:suffixText="cm"
                    android:hint="身高 (Height)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:suffixText="cm"
                    android:hint="臂展 (Wingspan)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etWingspan"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:suffixText="kg"
                    android:hint="当前体重 (Body Weight)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etBodyWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/btnSaveBodyMetrics"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="保存维度数据"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:backgroundTint="#00897B"
                    app:cornerRadius="12dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="重量默认单位"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/white">

            <RadioGroup
                android:id="@+id/unitRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp">
                <RadioButton
                    android:id="@+id/rbKg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="千克 (kg)"
                    android:padding="14dp"
                    android:textSize="16sp"
                    android:textColor="#37474F"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginHorizontal="14dp"/>

                <RadioButton
                    android:id="@+id/rbLbs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="磅 (lbs)"
                    android:padding="14dp"
                    android:textSize="16sp"
                    android:textColor="#37474F"/>
            </RadioGroup>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="新动作默认类型"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/white">

            <RadioGroup
                android:id="@+id/addStrategyRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="6dp">
                <RadioButton
                    android:id="@+id/rbAddToPlan"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="加入训练计划 (永久)"
                    android:padding="14dp"
                    android:textSize="16sp"
                    android:textColor="#37474F"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginHorizontal="14dp"/>

                <RadioButton
                    android:id="@+id/rbTemporary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="仅添加到今日 (临时)"
                    android:padding="14dp"
                    android:textSize="16sp"
                    android:textColor="#37474F"/>
            </RadioGroup>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数据管理"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#212121"/>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

            <LinearLayout
                android:id="@+id/btnOpenFolder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:padding="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数据文件夹"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#00897B"
                    android:layout_marginEnd="6dp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_folder"
                    app:tint="#00897B"/>
            </LinearLayout>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/btnBackup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="备份数据 (到手机存储)"
                    android:padding="18dp"
                    android:textSize="16sp"
                    android:textColor="#37474F"
                    android:gravity="center_vertical"
                    android:drawablePadding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    app:drawableStartCompat="@android:drawable/ic_menu_save"
                    app:drawableTint="#546E7A"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginHorizontal="14dp"/>

                <TextView
                    android:id="@+id/btnExportCsv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="导出 Excel 报表 (CSV)"
                    android:padding="18dp"
                    android:textSize="16sp"
                    android:textColor="#37474F"
                    android:gravity="center_vertical"
                    android:drawablePadding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    app:drawableStartCompat="@android:drawable/ic_menu_share"
                    app:drawableTint="#546E7A"/>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F5F5F5" android:layout_marginHorizontal="14dp"/>

                <TextView
                    android:id="@+id/btnRestore"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="从备份恢复"
                    android:padding="18dp"
                    android:textSize="16sp"
                    android:textColor="#37474F"
                    android:gravity="center_vertical"
                    android:drawablePadding="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:clickable="true"
                    app:drawableStartCompat="@android:drawable/ic_menu_revert"
                    app:drawableTint="#546E7A"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="危险区域"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#D32F2F"
            android:paddingHorizontal="16dp"
            android:paddingTop="28dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFEBEE">

            <TextView
                android:id="@+id/btnClearAllHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="清空所有历史记录"
                android:textColor="#C62828"
                android:textSize="16sp"
                android:padding="18dp"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:textStyle="bold"/>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>